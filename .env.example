# .env.local (never commit this file)
# ── Database ──────────────────────────────────────────────────────────────────
# Get these from Neon.tech → your project → Connection string
# The pooled URL goes through PgBouncer (required for serverless)

# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated Clerk userIds that have admin access
ADMIN_USER_IDS=user_xxxxxxxxxxxxxxxx

# Database
DATABASE_URL="postgresql://"
DIRECT_URL="postgresql://"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# run: openssl rand -base64 32
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# Your app passphrase — share this with your friends
APP_PASSPHRASE="************"